---
import Wordmark from './Wordmark.astro';
import { getCollection } from 'astro:content';
const projects = await getCollection('projects');
const latest = projects.map((p) => p.data.added).sort().at(-1) ?? '2026-07-19';
const fmt = new Date(latest + 'T12:00:00Z').toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const openCount = projects.filter((p) => p.data.license.verdict === 'open').length;
---
<footer class="site-footer">
  <div class="wrap">
    <div class="ft-grid">
      <div class="ft-brand">
        <Wordmark size={1.15} />
        <p class="ft-tag">The harbor where open-source AI comes ashore. Every project license-checked against the source.</p>
        <p class="ft-daybreak mono">Last daybreak — {fmt} · {openCount} verified-open projects</p>
      </div>
      <nav class="ft-col" aria-label="Explore">
        <h4>Explore</h4>
        <a href="/projects">All projects</a>
        <a href="/collections/daybreak">Daybreak</a>
        <a href="/collections/first-light">First Light</a>
        <a href="/collections/night-shift">Night Shift</a>
        <a href="/fine-print">The Fine Print</a>
      </nav>
      <nav class="ft-col" aria-label="The experiment">
        <h4>The experiment</h4>
        <a href="/about">About</a>
        <a href="/guide">Build guide</a>
        <a href="/methodology">Methodology</a>
        <a href="/credits">Credits</a>
        <a href="/rss.xml">RSS</a>
      </nav>
      <div class="ft-col">
        <h4>Corrections</h4>
        <p class="ft-note">Spotted a bad link, a stale status, or a license we got wrong? Corrections keep the tally honest — see the <a href="/methodology#corrections">methodology</a>.</p>
      </div>
    </div>
    <div class="ft-base">
      <span class="mono">DAIODA · daioda.io</span>
      <span class="mono ft-credit">Designed &amp; built autonomously by Fable 5 · An OLDCARTS experiment</span>
    </div>
  </div>
</footer>
<style>
  .site-footer { border-top: 1px solid var(--line); background: var(--bg-raised); margin-top: 5rem; padding: 3.5rem 0 2rem; }
  .ft-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.2fr; gap: 2.5rem; }
  .ft-tag { color: var(--ink-dim); font-size: 0.95rem; max-width: 34ch; margin-top: 1rem; }
  .ft-daybreak { font-size: 0.72rem; color: var(--accent); letter-spacing: 0.04em; }
  .ft-col h4 { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-faint); margin-bottom: 1rem; }
  .ft-col a { display: block; color: var(--ink-dim); font-size: 0.92rem; padding: 0.28em 0; transition: color 0.2s; }
  .ft-col a:hover { color: var(--accent); }
  .ft-note { color: var(--ink-dim); font-size: 0.88rem; }
  .ft-note a { color: var(--accent); }
  .ft-base { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.6rem; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--line); }
  .ft-base .mono { font-size: 0.74rem; color: var(--ink-faint); }
  .ft-credit { color: var(--ink-dim); }
  @media (max-width: 820px) { .ft-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 500px) { .ft-grid { grid-template-columns: 1fr; } }
</style>
