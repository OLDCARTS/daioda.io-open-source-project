---
import Wordmark from './Wordmark.astro';
const nav = [
  { href: '/projects', label: 'Discover' },
  { href: '/collections/daybreak', label: 'Daybreak' },
  { href: '/fine-print', label: 'The Fine Print' },
  { href: '/methodology', label: 'Method' },
  { href: '/guide', label: 'Guide' },
  { href: '/about', label: 'About' },
];
const here = Astro.url.pathname.replace(/\/$/, '');
---
<header class="site-header">
  <div class="wrap hdr-inner">
    <a href="/" class="brand" aria-label="DAIODA home"><Wordmark size={1.05} /></a>
    <nav class="nav" aria-label="Primary">
      {nav.map((n) => (
        <a href={n.href} class:list={["nav-link", { active: here === n.href || (n.href !== '/' && here.startsWith(n.href)) }]}>{n.label}</a>
      ))}
    </nav>
    <div class="hdr-right">
      <button id="theme-toggle" class="icon-btn" aria-label="Toggle daylight" title="Toggle night / daylight">
        <span class="theme-glyph" aria-hidden="true"></span>
      </button>
      <button id="menu-btn" class="icon-btn menu-btn" aria-label="Open menu" aria-expanded="false"><span></span><span></span></button>
    </div>
  </div>
  <div class="mobile-nav" id="mobile-nav" hidden>
    {nav.map((n) => <a href={n.href} class="mnav-link">{n.label}</a>)}
  </div>
</header>
<style>
  .site-header {
    position: sticky; top: 0; z-index: 50;
    backdrop-filter: blur(14px) saturate(1.3);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    border-bottom: 1px solid var(--line);
  }
  .hdr-inner { display: flex; align-items: center; gap: 1.5rem; height: 64px; }
  .brand { display: inline-flex; }
  .nav { display: flex; gap: 0.3rem; margin-left: auto; }
  .nav-link {
    font-size: 0.9rem; font-weight: 550; color: var(--ink-dim);
    padding: 0.45em 0.7em; border-radius: 100px;
    transition: color 0.2s, background 0.2s;
  }
  .nav-link:hover { color: var(--ink); }
  .nav-link.active { color: var(--accent); background: color-mix(in srgb, var(--accent) 10%, transparent); }
  .hdr-right { display: flex; align-items: center; gap: 0.4rem; }
  .icon-btn {
    display: grid; place-items: center; width: 38px; height: 38px;
    border-radius: 50%; border: 1px solid var(--line); background: transparent;
    color: var(--ink-dim); cursor: pointer; transition: all 0.2s;
  }
  .icon-btn:hover { color: var(--accent); border-color: var(--line-strong); }
  .theme-glyph { width: 16px; height: 16px; border-radius: 50%;
    background: radial-gradient(circle at 32% 32%, var(--gold), var(--ember));
    box-shadow: inset -3px -3px 0 0 color-mix(in srgb, var(--bg) 70%, transparent); }
  [data-theme='day'] .theme-glyph { box-shadow: none; background: radial-gradient(circle at 50% 50%, var(--gold), var(--ember)); }
  .menu-btn { display: none; flex-direction: column; gap: 4px; }
  .menu-btn span { width: 16px; height: 2px; background: currentColor; border-radius: 2px; }
  .mobile-nav { display: none; flex-direction: column; padding: 0.5rem 1.2rem 1rem; border-bottom: 1px solid var(--line); background: var(--bg-raised); }
  .mnav-link { padding: 0.7em 0.4em; color: var(--ink-dim); font-weight: 550; border-bottom: 1px solid var(--line); }
  .mnav-link:last-child { border-bottom: none; }
  @media (max-width: 860px) {
    .nav { display: none; }
    .menu-btn { display: flex; }
    .mobile-nav.open { display: flex; }
  }
</style>
<script>
  const t = document.getElementById('theme-toggle');
  t?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'day' ? 'night' : 'day';
    root.dataset.theme = next;
    try { localStorage.setItem('daioda-theme', next); } catch {}
  });
  const mb = document.getElementById('menu-btn');
  const mn = document.getElementById('mobile-nav');
  mb?.addEventListener('click', () => {
    const open = mn?.classList.toggle('open');
    if (mn) mn.hidden = !open;
    mb.setAttribute('aria-expanded', String(!!open));
  });
</script>
