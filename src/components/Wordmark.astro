---
interface Props { size?: number; class?: string; }
const { size = 1, class: cls = '' } = Astro.props;
---
<span class={`wordmark ${cls}`} style={`--s:${size}`} aria-label="DAIODA">
  <span class="wm-d">D</span><span class="wm-ai">AI</span><span class="wm-o">O</span><span class="wm-da">DA</span>
</span>
<style>
  .wordmark {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.02em;
    font-size: calc(1.35rem * var(--s));
    line-height: 1;
    display: inline-flex;
    white-space: nowrap;
    font-optical-sizing: auto;
  }
  .wm-ai { color: var(--wm-ai); }
  .wm-o {
    color: var(--wm-o);
    display: inline-block;
    position: relative;
  }
  .wm-d, .wm-da { color: var(--ink); }
</style>
