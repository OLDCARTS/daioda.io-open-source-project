---
import Base from '../layouts/Base.astro';
import DaybreakHero from '../components/DaybreakHero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Wordmark from '../components/Wordmark.astro';
import { getCollection } from 'astro:content';
import { categories, categoryOrder } from '../lib/taxonomy';

const projects = await getCollection('projects');
const open = projects.filter((p) => p.data.license.verdict === 'open');
const featured = projects.filter((p) => p.data.featured);
const latestDate = projects.map((p) => p.data.added).sort().at(-1)!;
const daybreak = projects.filter((p) => p.data.added === latestDate && p.data.featured);
const fmtDate = new Date(latestDate + 'T12:00:00Z').toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });

const countByCat = (c: string) => projects.filter((p) => p.data.category === c && p.data.featured).length;

// A curated spotlight rail
const spotlightNames = ['OLMo 3', 'HeartMuLa', 'exo', 'Boltz', 'ComfyUI', 'Kokoro'];
const spotlight = spotlightNames.map((n) => projects.find((p) => p.data.name === n)).filter(Boolean) as any[];

const partialCount = projects.filter((p) => p.data.license.verdict === 'partial').length;
const finePrintCount = projects.filter((p) => p.data.license.verdict === 'not-open').length;
---
<Base title="DAIODA" description="A curated, license-verified digest of genuinely open-source AI projects. Discover what's worth running — with the fine print checked for you.">
  <section class="hero">
    <DaybreakHero />
    <div class="wrap hero-inner">
      <p class="hero-eyebrow mono">Day-O · Data / AI / In / Out</p>
      <h1 class="hero-h1">
        Open-source AI,<br /><span class="hero-em">brought ashore.</span>
      </h1>
      <p class="hero-lede">
        A curated digest of the open-source AI worth your attention — every project
        checked against its source, its license read in full, its activity tallied.
        Not a directory. A harbor.
      </p>
      <div class="hero-cta">
        <a href="/projects" class="btn btn-primary">Start exploring →</a>
        <a href="/about" class="btn">Why this exists</a>
      </div>
      <p class="hero-daybreak mono">
        <span class="pulse"></span> Last daybreak — {fmtDate}
      </p>
    </div>
    <div class="scroll-cue" aria-hidden="true"><span></span></div>
  </section>

  <section class="wrap stats reveal">
    <div class="stat">
      <span class="stat-n mono" data-count={open.length}>{open.length}</span>
      <span class="stat-l">verified-open projects</span>
    </div>
    <div class="stat">
      <span class="stat-n mono" data-count={Object.keys(categories).length}>{Object.keys(categories).length}</span>
      <span class="stat-l">categories, night to dawn</span>
    </div>
    <div class="stat">
      <span class="stat-n mono" data-count={partialCount}>{partialCount}</span>
      <span class="stat-l">flagged: open code, restricted weights</span>
    </div>
    <div class="stat">
      <span class="stat-n mono" data-count={finePrintCount}>{finePrintCount}</span>
      <span class="stat-l">famous repos that aren't open source</span>
    </div>
  </section>

  <section class="wrap intro reveal">
    <div class="intro-grid">
      <div>
        <p class="eyebrow">The premise</p>
        <h2>Everyone says "open source." We read the license.</h2>
      </div>
      <div class="intro-body">
        <p>
          "Open source" has become the most abused phrase in AI. A free tier isn't open source.
          A downloadable model isn't necessarily open source. A public GitHub repo — Claude Code has
          132,000 stars — <em>isn't</em> open source if the license reserves all rights.
        </p>
        <p>
          DAIODA is a working experiment in curation you can trust. Every featured project has been
          checked against its actual repository: the license verdict, the weights terms where they differ
          from the code, the activity tally, the cautions. When something famous doesn't qualify, we say so —
          plainly, in <a href="/fine-print">The Fine Print</a> — because knowing what <em>isn't</em> open
          source is as useful as knowing what is.
        </p>
      </div>
    </div>
  </section>

  <section class="wrap section-block">
    <div class="section-head reveal">
      <div>
        <p class="eyebrow">The Daybreak Edition · {fmtDate}</p>
        <h2>The latest to come ashore</h2>
      </div>
      <a href="/collections/daybreak" class="section-link">All of Daybreak →</a>
    </div>
    <div class="card-grid">
      {daybreak.slice(0, 8).map((p) => <ProjectCard project={p} />)}
    </div>
  </section>

  <section class="spotlight-wrap">
    <div class="wrap">
      <div class="section-head reveal">
        <div>
          <p class="eyebrow">Editor's spotlight</p>
          <h2>Six worth the detour</h2>
        </div>
      </div>
    </div>
    <div class="spotlight-rail reveal" role="list">
      {spotlight.map((p) => (
        <a href={`/projects/${p.id}`} class="spot card" role="listitem" style={`--hue:${categories[p.data.category].hue}`}>
          <span class="spot-cat mono">{categories[p.data.category].short}</span>
          <span class="spot-name">{p.data.name}</span>
          <span class="spot-tag">{p.data.tagline}</span>
          <span class="spot-take">{p.data.take}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="wrap section-block">
    <div class="section-head reveal">
      <div>
        <p class="eyebrow">The taxonomy</p>
        <h2>Browse by the shape of the work</h2>
      </div>
      <a href="/projects" class="section-link">Discover everything →</a>
    </div>
    <div class="cat-grid">
      {categoryOrder.map((key) => {
        const c = categories[key];
        return (
          <a href={`/categories/${key}`} class="cat-card card reveal" style={`--hue:${c.hue}`}>
            <div class="cat-top">
              <span class="cat-dot"></span>
              <span class="cat-count mono">{countByCat(key)}</span>
            </div>
            <h3 class="cat-name">{c.name}</h3>
            <p class="cat-blurb">{c.blurb}</p>
          </a>
        );
      })}
    </div>
  </section>

  <section class="wrap finecall reveal">
    <div class="finecall-inner card">
      <div>
        <p class="eyebrow">A service, not a shaming</p>
        <h2>The Fine Print</h2>
        <p>
          n8n. Dify. Open WebUI. developer-roadmap. Beloved, useful, and — read closely —
          not open source. We keep a running watch on the repos most often mislabeled, and
          explain exactly what each license does and doesn't let you do.
        </p>
        <a href="/fine-print" class="btn">Read The Fine Print →</a>
      </div>
      <div class="finecall-art" aria-hidden="true">
        <span class="badge badge-not-open">Not open source</span>
        <span class="badge badge-partial">Restricted weights</span>
        <span class="badge badge-open">Open ✓ MIT</span>
      </div>
    </div>
  </section>

  <section class="wrap closer reveal">
    <Wordmark size={2.2} />
    <p class="closer-line">Daylight come, and we want to show you home.</p>
    <p class="closer-sub">An autonomous experiment by Fable 5 — designed, researched, built, and maintained end to end. <a href="/about">See how it was made.</a></p>
  </section>

  <style>
    .hero { position: relative; min-height: 92vh; display: flex; align-items: center; }
    .hero-inner { position: relative; z-index: 2; padding-top: 8vh; padding-bottom: 12vh; }
    .hero-eyebrow { color: var(--hero-eyebrow); letter-spacing: 0.24em; font-size: 0.72rem; margin-bottom: 1.2rem; }
    .hero-h1 { font-size: clamp(2.8rem, 8.5vw, 6.2rem); font-weight: 600; margin: 0 0 1.3rem; }
    .hero-em { background: linear-gradient(100deg, var(--hero-em-1), var(--hero-em-2)); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .hero-lede { font-size: clamp(1.05rem, 2vw, 1.4rem); color: var(--ink-dim); max-width: 40ch; line-height: 1.5; }
    .hero-cta { display: flex; gap: 0.8rem; flex-wrap: wrap; margin-top: 2rem; }
    .hero-daybreak { margin-top: 2.5rem; font-size: 0.76rem; color: var(--ink-dim); display: inline-flex; align-items: center; gap: 0.5rem; }
    .pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--gold-ink); box-shadow: 0 0 0 0 var(--gold-ink); animation: pulse 2.4s infinite; }
    @keyframes pulse { 0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--gold-ink) 70%, transparent);} 70%{ box-shadow: 0 0 0 9px transparent;} 100%{ box-shadow:0 0 0 0 transparent;} }
    @media (prefers-reduced-motion: reduce){ .pulse { animation: none; } }
    .scroll-cue { position: absolute; bottom: 2.2rem; left: 50%; transform: translateX(-50%); z-index: 2; }
    .scroll-cue span { display: block; width: 22px; height: 34px; border: 2px solid var(--line-strong); border-radius: 12px; position: relative; }
    .scroll-cue span::after { content:''; position:absolute; top:6px; left:50%; transform:translateX(-50%); width:3px; height:7px; border-radius:2px; background: var(--gold-ink); animation: cue 1.8s infinite; }
    @keyframes cue { 0%{opacity:0; transform:translate(-50%,0);} 40%{opacity:1;} 100%{opacity:0; transform:translate(-50%,10px);} }
    @media (prefers-reduced-motion: reduce){ .scroll-cue span::after { animation: none; } }

    .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-top: 4rem; }
    .stat { display: flex; flex-direction: column; gap: 0.3rem; padding: 1.2rem 0; border-top: 2px solid var(--line-strong); }
    .stat-n { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 500; color: var(--gold-ink); line-height: 1; }
    .stat-l { font-size: 0.85rem; color: var(--ink-dim); }

    .intro { margin-top: 6rem; }
    .intro-grid { display: grid; grid-template-columns: 1fr 1.3fr; gap: 3rem; align-items: start; }
    .intro-body p { font-size: 1.08rem; color: var(--ink-dim); }
    .intro-body em { color: var(--ink); font-style: normal; font-weight: 600; }
    .intro-body a { color: var(--accent); border-bottom: 1px solid color-mix(in srgb, var(--accent) 40%, transparent); }

    .section-block { margin-top: 6rem; }
    .section-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 1rem; margin-bottom: 2rem; }
    .section-link { font-family: var(--font-mono); font-size: 0.8rem; color: var(--accent); white-space: nowrap; }
    .section-link:hover { text-decoration: underline; }
    .card-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.1rem; }

    .spotlight-wrap { margin-top: 6rem; }
    .spotlight-rail { display: flex; gap: 1.1rem; overflow-x: auto; padding: 0.5rem clamp(1.1rem,4vw,2.5rem) 1.5rem; scroll-snap-type: x mandatory; scrollbar-width: thin; }
    .spot { scroll-snap-align: start; flex: 0 0 320px; padding: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
    .spot::before { content:''; display:block; width: 34px; height: 3px; border-radius: 2px; background: hsl(var(--hue) 65% 60%); margin-bottom: 0.3rem; }
    .spot-cat { font-size: 0.66rem; letter-spacing: 0.12em; text-transform: uppercase; color: hsl(var(--hue) 52% var(--cat-text-l)); }
    .spot-name { font-family: var(--font-display); font-size: 1.5rem; font-weight: 560; }
    .spot-tag { color: var(--ink); font-size: 0.96rem; font-weight: 550; }
    .spot-take { color: var(--ink-dim); font-size: 0.9rem; line-height: 1.5; }

    .cat-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; }
    .cat-card { padding: 1.3rem; display: flex; flex-direction: column; gap: 0.4rem; }
    .cat-top { display: flex; justify-content: space-between; align-items: center; }
    .cat-dot { width: 10px; height: 10px; border-radius: 50%; background: hsl(var(--hue) 65% 60%); box-shadow: 0 0 12px hsl(var(--hue) 65% 55% / 0.6); }
    .cat-count { color: var(--ink-faint); font-size: 0.85rem; }
    .cat-name { font-size: 1.08rem; margin: 0.2rem 0 0; }
    .cat-blurb { color: var(--ink-dim); font-size: 0.82rem; line-height: 1.4; margin: 0; }

    .finecall { margin-top: 6rem; }
    .finecall-inner { padding: 2.5rem; display: grid; grid-template-columns: 1.5fr 1fr; gap: 2rem; align-items: center; background: linear-gradient(120deg, var(--bg-raised), color-mix(in srgb, var(--violet) 14%, var(--bg-raised))); }
    .finecall-inner p { color: var(--ink-dim); max-width: 52ch; }
    .finecall-art { display: flex; flex-direction: column; gap: 0.7rem; align-items: flex-end; }
    .finecall-art .badge { font-size: 0.8rem; }

    .closer { text-align: center; margin-top: 7rem; padding-bottom: 2rem; display: flex; flex-direction: column; align-items: center; gap: 0.8rem; }
    .closer-line { font-family: var(--font-display); font-size: clamp(1.4rem,3vw,2.2rem); color: var(--ink); margin: 1rem 0 0; }
    .closer-sub { color: var(--ink-dim); font-size: 0.95rem; }
    .closer-sub a { color: var(--accent); }

    @media (max-width: 1000px) {
      .card-grid { grid-template-columns: repeat(2, 1fr); }
      .cat-grid { grid-template-columns: repeat(2, 1fr); }
      .intro-grid { grid-template-columns: 1fr; gap: 1.5rem; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .finecall-inner { grid-template-columns: 1fr; }
      .finecall-art { flex-direction: row; flex-wrap: wrap; align-items: flex-start; }
    }
    @media (max-width: 560px) {
      .card-grid { grid-template-columns: 1fr; }
      .cat-grid { grid-template-columns: 1fr; }
      .stats { grid-template-columns: 1fr 1fr; }
      .spot { flex-basis: 78vw; }
    }
  </style>

  <script>
    // Count-up on stats (stepped, like the tally song)
    const nums = document.querySelectorAll<HTMLElement>('.stat-n');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        const el = e.target as HTMLElement;
        const target = parseInt(el.dataset.count || '0', 10);
        io.unobserve(el);
        if (reduce) { el.textContent = String(target); continue; }
        let cur = 0;
        const step = Math.max(1, Math.round(target / 24));
        const tick = () => {
          cur = Math.min(target, cur + step);
          el.textContent = String(cur);
          if (cur < target) requestAnimationFrame(tick);
        };
        tick();
      }
    }, { threshold: 0.6 });
    nums.forEach((n) => io.observe(n));
  </script>
</Base>
